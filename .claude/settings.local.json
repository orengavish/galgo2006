{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Write(*)",
      "Edit(*)",
      "mcp__galao_db__*"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "galao-db"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Projects/galgo2026/.claude/hooks/selftest_on_edit.py",
            "timeout": 35,
            "statusMessage": "Running --self-test..."
          }
        ]
      }
    ]
  }
}
